# OpenAI API Key (wajib) — bisa pakai OpenAI, DeepSeek, Groq, dll.
OPENAI_API_KEY=sk-isi_dengan_api_key_kamu

# Base URL API (default DeepSeek)
OPENAI_BASE_URL=https://api.deepseek.com/v1

# Model yang dipakai
OPENAI_MODEL=deepseek-v4-pro

# System prompt diatur dari dashboard (menu Settings), tersimpan di DB — bukan di sini.

# Database MySQL (data aplikasi: user, chat history, settings, knowledge)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=wa_assistant

# Path DB SQLite (khusus sesi WhatsApp/whatsmeow)
DB_PATH=./wa-assistant.db

# JWT secret untuk login
JWT_SECRET=ganti_dengan_string_acak

# Port server backend
PORT=3030

# --- Keamanan & performa (opsional; default aman untuk dev) ---
# Batasi origin CORS di produksi (daftar dipisah koma). Default "*" (longgar) untuk dev.
# Contoh prod: CORS_ALLOWED_ORIGINS=http://103.181.143.107:8080
CORS_ALLOWED_ORIGINS=*
# Masa berlaku token login (jam) & token media (menit).
TOKEN_TTL_HOURS=24
MEDIA_TOKEN_TTL_MIN=30
# Throttle login: jendela hitung & lama kunci (menit).
LOGIN_WINDOW_MIN=10
LOGIN_LOCK_MIN=10
# Connection pool MySQL.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30
# Batas nomor saat trial (default 1).
TRIAL_MAX_NUMBERS=1

# --- SaaS multi-tenant ---
# Operator platform (login ke /admin). GANTI di production.
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123
# Lama masa trial (hari) untuk pendaftar baru.
TRIAL_DAYS=7
# Batas balasan AI/bulan saat masih trial (cegah abuse).
TRIAL_AI_REPLIES=100

# --- Pembayaran Tripay ---
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_MODE=sandbox
# URL pelanggan dikembalikan setelah bayar (opsional).
TRIPAY_RETURN_URL=http://localhost:5173/app
# Set di dashboard Tripay -> URL Callback:
#   https://domainmu/api/billing/tripay/callback

# Embedding untuk semantic search knowledge base (opsional).
# Kosongkan EMBEDDING_API_KEY untuk nonaktif (fallback ke keyword match).
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=
